<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ai_chatbot_conversation_list" model="ir.ui.view">
        <field name="name">ai.chatbot.conversation.list</field>
        <field name="model">ai.chatbot.conversation</field>
        <field name="arch" type="xml">
            <list string="Conversations">
                <field name="name"/>
                <field name="user_id"/>
                <field name="message_count"/>
                <field name="write_date"/>
            </list>
        </field>
    </record>

    <record id="view_ai_chatbot_conversation_form" model="ir.ui.view">
        <field name="name">ai.chatbot.conversation.form</field>
        <field name="model">ai.chatbot.conversation</field>
        <field name="arch" type="xml">
            <form string="Conversation">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="user_id"/>
                        <field name="config_id"/>
                    </group>
                    <field name="message_ids">
                        <list>
                            <field name="create_date"/>
                            <field name="role"/>
                            <field name="content"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_chatbot_conversation" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">ai.chatbot.conversation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
